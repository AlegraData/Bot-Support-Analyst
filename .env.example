# Base de datos
# En local usa el direct connection (puerto 5432)
# En Vercel usa el Transaction pooler de Supabase (puerto 6543, Session mode)
# Supabase -> Settings -> Database -> Connection string -> Transaction pooler
DATABASE_URL=""

# Gemini API (Google AI Studio -> https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=""

# URL publica de la app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase Auth (Settings -> API en tu proyecto de Supabase)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
